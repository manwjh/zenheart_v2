# Local deploy configuration — copy to .deploy-env and fill in real values.
# .deploy-env is gitignored; never commit it.

# EC2 host IP or hostname (required)
export ZENHEART_EC2_HOST=

# SSH host key pinning (required unless you opt in below). Example:
#   mkdir -p v2/.ssh
#   ssh-keyscan -H "$ZENHEART_EC2_HOST" >>v2/.ssh/known_hosts
#   export ZENHEART_SSH_KNOWN_HOSTS="$PWD/v2/.ssh/known_hosts"
# export ZENHEART_SSH_KNOWN_HOSTS=

# Less safe: trust host key on first connect (MITM risk). Only if you cannot maintain known_hosts.
# export ZENHEART_SSH_ACCEPT_NEW=1

# Path to EC2 SSH private key (default: ../aws/zenheart-ec2.pem relative to v2/)
# export ZENHEART_EC2_KEY=/path/to/zenheart-ec2.pem

# EC2 login user (default: ec2-user)
# export ZENHEART_EC2_USER=ec2-user

# Remote directory for the backend service
# export ZENHEART_V2_REMOTE_DIR=/opt/zenheart/services/v2_backend

# Optional: local OpenClaw skill bundle directory for deploy-{backend,faq-files}.sh (default: zenheart-agent/skills sibling to v2/)
# export ZENHEART_SKILLS_DIR=/abs/path/to/zenheart-agent/skills

# Remote web root for the frontend dist
# export ZENHEART_WEB_DIR=/opt/zenheart/frontend

# Set to 1 to skip nginx fragment install
# export ZENHEART_V2_SKIP_NGINX=0

# Backend deploy: omit v2/docs + zenheart-agent/skills tarballs (default 0). When 1, run ./deploy-faq-files.sh to sync FAQ trees.
# export ZENHEART_V2_SKIP_DOCS_SKILLS_BUNDLE=0

# First-time only: copy remote .env.example -> .env when .env is missing (otherwise deploy fails).
# export ZENHEART_V2_BOOTSTRAP_ENV=1

# Optional: cap entire remote SSH session for backend deploy (default 1800 seconds).
# export ZENHEART_V2_REMOTE_SSH_MAX_S=3600

# Frontend rsync staging folder under remote $HOME (single segment; default zenheart-v2-frontend-dist).
# export ZENHEART_V2_STAGING=zenheart-v2-frontend-dist

# Optional: media root on server (default /opt/zenheart/media). Must stay under /opt/zenheart/.
# export ZENHEART_MEDIA_ROOT=/opt/zenheart/media

# Full stack (backend then frontend, same EC2): from repo root ./v2/deploy-production.sh
# Or separately from v2/: ./deploy-backend.sh then ./deploy-frontend.sh
#
# High-churn content (optional workflow): keep SPA + API deploys free of unrelated trees and (if desired) FAQ trees.
# - zenlink/: never overwritten by deploy-frontend.sh (legacy or operator-managed paths only; not produced by v2/frontend).
# - v2/docs + zenheart-agent/skills: set ZENHEART_V2_SKIP_DOCS_SKILLS_BUNDLE=1 and ./deploy-faq-files.sh when Markdown/skills change.

# Deploy backend only (from repo v2/): ./deploy-backend.sh
# Remote steps: venv+pip, rotate ADMIN_API_KEY every run (writes remote .env, prints key in SSH log),
# install psql when missing (dnf/yum/apt), run scripts/migrations/*.sql via Python, restart systemd.
# Skip key rotation (keep existing ADMIN_API_KEY):
# export ZENHEART_V2_NO_ROTATE_ADMIN_KEY=1
#
# After migrations, before systemd restart: upsert AI Agent Check-in with creator_agent_id=system:
# export ZENHEART_V2_STANDARDIZE_CHECKIN_SYSTEM=1

# After deploy, copy current remote key to v2/.last-admin-api-key (gitignored):
# export ZENHEART_V2_SAVE_LAST_ADMIN_KEY=1

# FAQ docs / skills only (rsync, no pip/migrations/systemd restart): from v2/
#   ./deploy-faq-files.sh
#
# Frequent protocol markdown / skills churn without backend code changes:
#   export ZENHEART_V2_SKIP_DOCS_SKILLS_BUNDLE=1   # in v2/.deploy-env
#   ./deploy-backend.sh          # updates Python only; leaves remote docs/ + skills/ untouched
#   ./deploy-faq-files.sh        # rsync v2/docs + zenheart-agent/skills when prose changes
# First-time host: run at least one full backend deploy without SKIP, or deploy-faq-files once, so remote docs exist.
#
# Dry-run or verify remote matches local (exit 1 if drift):
#   ./deploy-faq-files.sh --dry-run
#   ./deploy-faq-files.sh --check-only
# Optional mirror v2/packages → remote sibling packages/ (not used by GET /v2/faq today):
#   ./deploy-faq-files.sh --with-packages

# Same secret as backend SOCIAL_OBSERVE_SHARED_TOKEN; used by deploy-frontend.sh → vite build.
# export VITE_SOCIAL_OBSERVE_TOKEN=
