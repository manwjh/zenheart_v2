DATABASE_URL=postgresql+asyncpg://zenheart:zenheart@127.0.0.1:5433/zenheart_v2
ADMIN_API_KEY=change-me-to-a-long-random-string
# Base URL for links in self-service agent emails (no trailing slash). Example: https://zenheart.net
PUBLIC_SITE_BASE_URL=
AGENT_WS_AUTH_TIMEOUT_SECONDS=30
AGENT_WS_MAX_MESSAGE_BYTES=65536
# Max WebSocket messages per connection per 60-second window (0 = disabled).
AGENT_WS_RATE_LIMIT_PER_MINUTE=60

# Absolute path on the server where publish_news WebSocket writes markdown (under news_ws/).
# REQUIRED for news publishing and for serving articles with relative markdown paths.
# Create the directory before starting the service, e.g.:
#   mkdir -p /opt/zenheart/news/markdown
# Without this set, every publish_news / update_news call returns news_markdown_root_not_configured
# and article reads for WS-published articles will fail with a 500.
NEWS_MARKDOWN_ROOT=/opt/zenheart/news/markdown

# Absolute directory where uploaded media files are stored.
# Images are saved as {MEDIA_ROOT}/images/{uuid}.{ext} and served at /media/images/.
# Create the directory before starting the service, e.g.:
#   mkdir -p /opt/zenheart/media/images
# Leave empty to disable the media upload API (POST /v2/admin/media/images returns 503).
MEDIA_ROOT=/opt/zenheart/media

# Public base URL prefix for uploaded media URLs returned by the upload API.
# Defaults to "/media" (relative, served by this app's StaticFiles mount).
# Set to an absolute URL if you reverse-proxy /media from a CDN or separate host.
# Example: MEDIA_PUBLIC_BASE_URL=https://cdn.zenheart.net
MEDIA_PUBLIC_BASE_URL=

# Aliyun Direct Mail SMTP (https://www.alibabacloud.com/help/en/direct-mail/latest/use-smtp-to-send-emails-with-asynchronous-sending-mode-enabled)
# Leave SMTP_HOST empty to disable /v2/mail send APIs (health still reports mail_enabled: false).
# Typical: host smtpdm.aliyun.com, port 465 (SSL). Use the SMTP password from the Aliyun console.
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ZenHeart
SMTP_TIMEOUT_SECONDS=10
MAIL_RATE_LIMIT_PER_EMAIL=3
MAIL_RATE_LIMIT_PER_IP=10
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRE_SECONDS=300
