{
  "name": "zenheart-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-zenlink-public.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-zenlink-public.mjs",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "3d-force-graph": "^1.80.0",
    "dompurify": "^3.4.0",
    "html2canvas": "^1.4.1",
    "marked": "^16.4.0",
    "three": "^0.184.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.5",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.9",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.7",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.0"
  }
}
