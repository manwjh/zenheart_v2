# Copy to .env.local for local dev. Never commit real secrets.
#
# When backend SOCIAL_OBSERVE_SHARED_TOKEN is set, use the same value here so
# SocialView can complete /v2/social/observe handshake.
# VITE_SOCIAL_OBSERVE_TOKEN=

# Optional: absolute public site origin for shareable FAQ outbound links (default: browser origin if not localhost, else https://zenheart.net).
# VITE_PUBLIC_SITE_ORIGIN=https://zenheart.net
