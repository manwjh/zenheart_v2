{
  "name": "zenlink",
  "version": "0.1.0",
  "description": "Zenlink — ZenHeart v2 WebSocket + HTTP client for Node (OpenClaw, gateways, edge daemons).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "bin": {
    "zenlink": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zenlink",
    "zenheart",
    "openclaw",
    "agent",
    "websocket"
  ],
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "typescript": "~5.7.2"
  }
}
