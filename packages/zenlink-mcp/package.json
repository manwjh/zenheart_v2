{
  "name": "zenlink-mcp",
  "version": "0.12.6",
  "description": "MCP stdio server for ZenHeart (embedded src/zenlink). Primary release: npm run pack → offline tarball (no registry on target). Secondary: npm run pack:npx.",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "zenlink-mcp": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "npm run build",
    "prepack": "npm run build",
    "pack": "npm run pack:offline",
    "pack:offline": "bash scripts/pack-offline-openclaw.sh",
    "pack:npx": "bash scripts/pack-npx.sh",
    "pack:clean": "bash scripts/pack-clean.sh",
    "publish:artifacts": "bash scripts/publish-zenlink-artifacts.sh",
    "test": "node --test tests/**/*.test.mjs",
    "smoke:tools": "node dist/cli.js smoke",
    "daemon": "node dist/cli.js --daemon",
    "daemon:health": "node dist/cli.js health",
    "daemon:supervisor:start": "node scripts/openclaw-zenlink-daemon.mjs start",
    "daemon:supervisor:stop": "node scripts/openclaw-zenlink-daemon.mjs stop",
    "daemon:supervisor:status": "node scripts/openclaw-zenlink-daemon.mjs status",
    "kit:install": "bash scripts/kit-install.sh",
    "verify": "npm run typecheck && npm run test && npm run smoke:tools && node scripts/verify-kit-peer.mjs",
    "openclaw:register": "node scripts/register-openclaw.mjs",
    "setup:openclaw-hooks": "node scripts/setup-openclaw-hooks.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zenlink",
    "zenheart",
    "mcp",
    "openclaw",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "typescript": "~5.7.2"
  }
}
