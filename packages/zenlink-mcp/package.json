{
  "name": "zenlink-mcp",
  "version": "0.13.25",
  "description": "MCP stdio server for ZenHeart (embedded Zenlink). 中文可检索关键词：禅心。OpenClaw: packaged tarball only (npm run pack → scripts/pack-offline.mjs → zenlink-mcp-openclaw-macos-v* + linux-v*; install-openclaw.sh + daemon). npm run pack:npx is npm publish tooling only.",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./server": {
      "types": "./dist/transport/server.d.ts",
      "import": "./dist/transport/server.js"
    },
    "./zenlink": {
      "types": "./dist/zenlink/index.d.ts",
      "import": "./dist/zenlink/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "zenlink-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "npm run build",
    "prepack": "npm run build",
    "pack": "npm run pack:offline",
    "pack:offline": "node scripts/pack-offline.mjs",
    "pack:offline:macos": "ZENLINK_MCP_OFFLINE_TARGETS=macos node scripts/pack-offline.mjs",
    "pack:offline:linux": "ZENLINK_MCP_OFFLINE_TARGETS=linux node scripts/pack-offline.mjs",
    "pack:verify": "node scripts/verify-offline-pack.mjs",
    "pack:release": "npm run verify && npm run pack && npm run pack:verify",
    "pack:npx": "bash scripts/pack-npx.sh",
    "pack:clean": "bash scripts/pack-clean.sh",
    "publish:artifacts": "bash scripts/publish-zenlink-artifacts.sh",
    "test": "node --test tests/**/*.test.mjs",
    "smoke:tools": "node dist/cli.js smoke",
    "daemon": "node dist/cli.js --daemon",
    "daemon:health": "node dist/cli.js health",
    "daemon:supervisor:start": "node scripts/openclaw-zenlink-daemon.mjs start",
    "daemon:supervisor:stop": "node scripts/openclaw-zenlink-daemon.mjs stop",
    "daemon:supervisor:status": "node scripts/openclaw-zenlink-daemon.mjs status",
    "verify": "npm run typecheck && npm run test && npm run smoke:tools && node scripts/verify-kit-peer.mjs",
    "openclaw:register": "node scripts/register-openclaw.mjs",
    "setup:openclaw-hooks": "node scripts/setup-openclaw-hooks.mjs",
    "verify:openclaw-wake": "node scripts/verify-openclaw-wake.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zenlink",
    "zenheart",
    "禅心",
    "mcp",
    "openclaw",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "typescript": "~5.7.2"
  }
}
